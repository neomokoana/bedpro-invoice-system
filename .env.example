# ════════════════════════════════════════════════════════════════════
#  Bed Pro Invoice System — environment template
#
#  Copy to .env (or .env.local) and fill in. .env is gitignored.
#  Vercel: paste these into Project Settings → Environment Variables.
# ════════════════════════════════════════════════════════════════════

# ── DATABASE (Supabase Postgres) ─────────────────────────────────────
# Get both from Supabase Dashboard → Project Settings → Database → Connection string.
#
# DATABASE_URL = Transaction pooler URL (port 6543, has ?pgbouncer=true).
#                Used at runtime by Prisma (via the pg adapter).
# DIRECT_URL   = Direct connection URL (port 5432).
#                Used by `prisma db push` / `prisma migrate` only.
#
# Replace [REF], [REGION] and [YOUR-PASSWORD] with your real values.
DATABASE_URL="postgresql://postgres.[REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── NEXTAUTH / AUTH.JS ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32   (or `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`)
NEXTAUTH_SECRET=""

# Local dev: http://localhost:3000
# Production: your Vercel/custom domain (e.g. https://bedpro-invoice-system.vercel.app)
# This is baked into invite-email login links — set correctly per environment.
NEXTAUTH_URL="http://localhost:3000"

# ── SUPABASE CLIENT (optional — Storage, Realtime) ───────────────────
# Project Settings → API in Supabase.
NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# server-only secret; never expose. Only needed if you use Storage uploads.
SUPABASE_SERVICE_ROLE_KEY=""

# ── FIRST ADMIN (consumed by `pnpm db:seed` only) ────────────────────
# Used once to create the initial admin. After seed, leave or remove.
# Password must be at least 12 chars (the seed throws otherwise).
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Bed Pro Admin"

# ── EMAIL (Nodemailer SMTP — SendGrid by default) ────────────────────
# If SMTP_PASSWORD is blank, email sending is skipped and:
#   - Invited users do NOT receive their temp password by email
#     (admin sees it inline after invite instead).
#   - "Email invoice to customer" fails with a generic error.
#
# To enable real email with SendGrid (free tier: 100 emails/day):
#   1. Sign up at https://signup.sendgrid.com
#   2. Verify a sender email matching EMAIL_FROM
#      (Settings → Sender Authentication → Single Sender Verification)
#   3. Create an API key with `Mail Send` scope
#   4. Paste the key as SMTP_PASSWORD below
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASSWORD=""
EMAIL_FROM="Bed Pro <invoices@bedpro.org.za>"

# ── OBSERVABILITY (optional) ─────────────────────────────────────────
# When set, server-side errors are reported to Sentry. Without it the app
# still logs to stdout (which Vercel captures in its dashboard).
SENTRY_DSN=""

# ── RATE LIMITING (optional but recommended for production) ──────────
# When set, login + invite + reset endpoints rate-limit per IP via Upstash.
# Without these, the app relies only on per-account lockout (5 strikes / 15 min).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
