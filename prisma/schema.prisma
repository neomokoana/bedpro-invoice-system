// Bed Pro Invoice System — Prisma schema (7 tables).
// Single-tenant. 3 flat roles: ADMIN, MANAGER, STAFF.
// Connection URLs come from prisma.config.ts for the CLI (db push/migrate)
// and from the pg adapter in src/lib/prisma.ts for runtime queries.

generator client {
  provider = "prisma-client-js"
  // (driver adapters are stable in Prisma 7 — no preview flag needed.)
}

datasource db {
  // Prisma 7: connection URL is NOT set here. It's read from prisma.config.ts
  // for CLI operations (db push, migrate) and from src/lib/prisma.ts (pg adapter)
  // at runtime.
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  SENT
  PAID
  // OVERDUE is not stored — it is computed live from dueDate.
}

enum PaymentMethod {
  EFT
  CARD
  CASH
  OTHER
}

// ────────────────────────────────────────────────────────────────
// User — system users (ADMIN / MANAGER / STAFF)
// `mustChangePassword` forces the set-password flow on first login.
// ────────────────────────────────────────────────────────────────
model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String
  passwordHash       String
  role               Role      @default(STAFF)
  branch             String?
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(true)
  lastLoginAt        DateTime?
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  invoicesCreated Invoice[] @relation("InvoiceCreator")
  receiptsCreated Receipt[] @relation("ReceiptCreator")

  @@index([email])
  @@map("users")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  company   String?
  email     String?
  phone     String?
  address   String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@index([name])
  @@index([email])
  @@map("customers")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String?
  unitPrice   Decimal  @db.Decimal(12, 2)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoiceItems InvoiceItem[]

  @@index([name])
  @@index([category])
  @@map("products")
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  customerId  String
  status      InvoiceStatus @default(DRAFT)
  issueDate   DateTime      @db.Date
  dueDate     DateTime      @db.Date
  paidAt      DateTime?
  taxRate     Decimal       @default(15) @db.Decimal(5, 2)
  discount    Decimal       @default(0) @db.Decimal(5, 2)
  subtotal    Decimal       @default(0) @db.Decimal(12, 2)
  discountAmt Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount   Decimal       @default(0) @db.Decimal(12, 2)
  total       Decimal       @default(0) @db.Decimal(12, 2)
  notes       String?
  emailedAt   DateTime?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  customer  Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User          @relation("InvoiceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items     InvoiceItem[]
  receipts  Receipt[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([createdById])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  qty         Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([productId])
  @@map("invoice_items")
}

model Receipt {
  id          String        @id @default(cuid())
  number      String        @unique
  invoiceId   String
  amount      Decimal       @db.Decimal(12, 2)
  paymentDate DateTime      @db.Date
  method      PaymentMethod @default(EFT)
  reference   String?
  notes       String?
  createdById String
  createdAt   DateTime      @default(now())

  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ReceiptCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@map("receipts")
}

model CompanySettings {
  id                 String   @id @default("singleton")
  name               String   @default("Bed Pro")
  legalName          String?
  address            String?
  phone              String?
  email              String?
  website            String?
  vatNumber          String?
  registrationNumber String?
  logoUrl            String?
  currency           String   @default("ZAR")
  taxRate            Decimal  @default(15) @db.Decimal(5, 2)
  invoicePrefix      String   @default("BP-")
  invoiceCounter     Int      @default(0)
  receiptPrefix      String   @default("RCP-")
  receiptCounter     Int      @default(0)
  bankName           String?
  bankBranch         String?
  bankAccountName    String?
  bankAccountNumber  String?
  updatedAt          DateTime @updatedAt

  @@map("company_settings")
}
